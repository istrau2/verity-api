# Per-environment, non-secret config for `--env production` (committed).
# Secrets like LLM_API_KEY go in `.env` (git-ignored), not here.
PORT=8790
# OpenRouter pinned to one host — same pin as dev so cached decompositions
# stay wording-consistent across environments.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-3.3-70b-instruct
LLM_PROVIDER_ORDER=DeepInfra
LLM_ALLOW_FALLBACKS=false
# Lock this down to your extension/site origins in production.
ALLOW_ORIGIN=https://en.wikipedia.org

# Gateway: server-to-server app API + read-only chain access (mainnet C-Chain).
APP_API_BASE=https://verisphere.co/api
RPC_URL=https://api.avax.network/ext/bc/C/rpc
CHAIN_ID=43114
