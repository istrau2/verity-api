# Per-environment, non-secret config for `--env dev` (committed).
# Secrets like LLM_API_KEY go in `.env` (git-ignored), not here.
PORT=8790
# OpenRouter, pinned to one host: decomposition wording must be deterministic
# (canonical texts drive cache keys + claim-group identity), and different
# hosts quantize the "same" model differently. Change the pin to taste.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-3.3-70b-instruct
LLM_PROVIDER_ORDER=DeepInfra
LLM_ALLOW_FALLBACKS=false
ALLOW_ORIGIN=*

# Gateway: server-to-server app API + read-only chain access (Fuji).
APP_API_BASE=https://test.verisphere.co/api
RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
CHAIN_ID=43113
