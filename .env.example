# SECRETS go here in `.env` (copy this file to `.env`). Git-ignored.
# Per-environment NON-secret config lives in `.env.dev` / `.env.production`,
# selected with `--env <name>`. Loading order: `.env.<name>` wins, then `.env`
# fills in secrets. So the only thing that needs to be here is the API key.

# LLM API key (OpenRouter — https://openrouter.ai/keys).
# The old GROQ_API_KEY name still works as a fallback.
LLM_API_KEY=

# Optional overrides (normally set per-env in .env.<name> instead):
# Any OpenAI-compatible endpoint works. Examples:
#   OpenRouter:      LLM_BASE_URL=https://openrouter.ai/api/v1     LLM_MODEL=meta-llama/llama-3.3-70b-instruct
#   Groq:            LLM_BASE_URL=https://api.groq.com/openai/v1   LLM_MODEL=llama-3.3-70b-versatile
#   OpenAI:          LLM_BASE_URL=https://api.openai.com/v1        LLM_MODEL=gpt-4o-mini
#   Ollama (local):  LLM_BASE_URL=http://localhost:11434/v1        LLM_MODEL=qwen2.5:14b-instruct
# OpenRouter host pinning (keeps canonical wording deterministic):
#   LLM_PROVIDER_ORDER=DeepInfra     # comma-separated, in preference order
#   LLM_ALLOW_FALLBACKS=false        # true = other hosts may serve if pin is down
# PORT=8790
# ALLOW_ORIGIN=*

# Article decomposition (defaults shown):
# DECOMPOSE_MAX_SENTENCES=200
# DECOMPOSE_CONCURRENCY=4
# DECOMPOSITION_TTL_MS=604800000   # 7 days
# RESOLVED_TTL_MS=3600000          # 60 minutes

# Cache backend: set REDIS_URL for a shared cache across replicated instances
# (recommended in production); unset falls back to a local SQLite file.
# REDIS_URL=redis://localhost:6379
# CACHE_DIR=./data                 # SQLite fallback location
