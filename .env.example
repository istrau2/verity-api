# SECRETS go here in `.env` (copy this file to `.env`). Git-ignored.
# Per-environment NON-secret config lives in `.env.dev` / `.env.production`,
# selected with `--env <name>`. Loading order: `.env.<name>` wins, then `.env`
# fills in secrets. So the only thing that needs to be here is the API key.

# Groq API key — https://console.groq.com/keys
GROQ_API_KEY=

# Optional overrides (normally set per-env in .env.<name> instead):
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# PORT=8790
# ALLOW_ORIGIN=*
